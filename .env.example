# Exemple de configuration — copie ce fichier en `.env.local` et remplis-le.
# (.env.local est ignoré par git et ne sera jamais commité.)

# ─── Option A : mode proxy (RECOMMANDÉ si tu distribues l'app) ────────────────
# Voir server/README.md. La vraie clé OpenAI vit sur le serveur, pas ici.
EXPO_PUBLIC_PROXY_URL=
EXPO_PUBLIC_APP_TOKEN=

# ─── Option B : clé directe (pratique pour développer seul) ──────────────────
# ⚠️ NE PAS distribuer un build avec cette valeur renseignée : elle finit dans
# le bundle de l'app et devient extractible. À réserver à ton usage local.
EXPO_PUBLIC_OPENAI_KEY=
