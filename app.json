{
  "expo": {
    "name": "FitTrackIA",
    "slug": "fittrackia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fittrackia",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080a0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fittrackia.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FitTrackIA utilise la caméra pour scanner les codes-barres des aliments."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080a0e"
      },
      "package": "com.fittrackia.app",
      "permissions": ["CAMERA"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7c6dfa"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FitTrackIA utilise la caméra pour scanner les codes-barres des aliments."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
