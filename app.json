{
  "expo": {
    "name": "FitTrackIA",
    "slug": "fittrackia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "fittrackia",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.fittrackia.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FitTrackIA utilise la caméra pour scanner les codes-barres des aliments.",
        "NSPhotoLibraryUsageDescription": "FitTrackIA accède à tes photos pour enregistrer tes photos de progression."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0A0A0B"
      },
      "package": "com.fittrackia.app",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#E8B84B"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FitTrackIA utilise la caméra pour scanner les codes-barres des aliments."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "FitTrackIA accède à tes photos pour enregistrer tes photos de progression."
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
